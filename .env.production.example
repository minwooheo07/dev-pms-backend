# ───────── NCP 서버 배포용 환경변수 ─────────
# 이 파일을 서버에서 .env 로 복사한 뒤 실제 값으로 채우세요.
# 비밀값(POSTGRES_PASSWORD, JWT_*_SECRET)은 반드시 강력하게 변경!

# PostgreSQL (docker-compose 의 db 서비스가 이 값으로 생성됨)
POSTGRES_USER=pms
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pms_db

# JWT 시크릿 — 무작위 긴 문자열로 교체 (예: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_random_secret
JWT_ACCESS_SECRET=CHANGE_ME_random_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 허용할 CORS 출처 (콤마 구분). 웹 프론트 + 앱 개발자 도메인.
# 개발 초기엔 모두 허용하려면 *  (운영 전엔 좁히기)
CORS_ORIGINS=http://localhost:5173
