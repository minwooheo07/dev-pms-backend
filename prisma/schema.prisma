generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  avatar     String?
  role       Role     @default(MEMBER)
  position   String?
  department String?
  phone      String?
  statusEmoji String? @default("🟢")
  statusText  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectMembers  ProjectMember[]
  assignedTasks   TaskAssignee[]
  comments        Comment[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  refreshTokens   RefreshToken[]
  createdProjects Project[]    @relation("ProjectCreator")
  createdTasks    Task[]       @relation("TaskCreator")
  uploadedFiles   Attachment[]
  workLogs        WorkLog[]
  createdMeetings      Meeting[]             @relation("MeetingCreator")
  meetingParticipants  MeetingParticipant[]
  createdIssues   Issue[]      @relation("IssueCreator")
  assignedIssues  Issue[]      @relation("IssueAssignee")
  createdNotices  Notice[]     @relation("NoticeCreator")
  createdCanvases Canvas[]     @relation("CanvasCreator")
  canvasComments  CanvasComment[] @relation("CanvasCommentAuthor")
  createdSheets   Sheet[]      @relation("SheetCreator")
  sentMessages     Message[]   @relation("MessageSender")
  receivedMessages Message[]   @relation("MessageRecipient")
  createdTemplates Template[]   @relation("TemplateCreator")
  createdRooms     Room[]      @relation("RoomCreator")
  roomMembers      RoomMember[]
  roomMessages     RoomMessage[] @relation("RoomMessageSender")
}

enum Role {
  ADMIN
  MEMBER
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  openDate    DateTime?
  color       String        @default("#6366f1")
  icon        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdById String
  createdBy   User          @relation("ProjectCreator", fields: [createdById], references: [id])

  members      ProjectMember[]
  steps        Step[]
  tasks        Task[]
  labels       Label[]
  activityLogs ActivityLog[]
  meetings     Meeting[]
  issues       Issue[]
  notices      Notice[]
  canvases     Canvas[]
  sheets       Sheet[]
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  ON_HOLD
}

model ProjectMember {
  id       String      @id @default(uuid())
  role     ProjectRole @default(MEMBER)
  joinedAt DateTime    @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Step (Kanban Column / Project Phase) ────────────────────────────────────

model Step {
  id        String   @id @default(uuid())
  name      String
  order     Int      @default(0)
  color     String   @default("#e2e8f0")
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  requester   String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  startDate   DateTime?
  dueDate     DateTime?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stepId      String?
  step        Step?   @relation(fields: [stepId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User    @relation("TaskCreator", fields: [createdById], references: [id])
  parentId    String?
  parentTask  Task?   @relation("SubTasks", fields: [parentId], references: [id])

  subTasks     Task[]         @relation("SubTasks")
  assignees    TaskAssignee[]
  comments     Comment[]
  attachments  Attachment[]
  labels       TaskLabel[]
  activityLogs ActivityLog[]
  personnel    TaskPersonnel[]
  workLogs     WorkLog[]
}

// ─── Partner (파트너사) & Personnel (인력) ──────────────────────────────────────

model Partner {
  id          String   @id @default(uuid())
  name        String
  description String?
  contactName String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personnel Personnel[]
}

model Personnel {
  id        String   @id @default(uuid())
  name      String
  position  String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  tasks TaskPersonnel[]
}

model TaskPersonnel {
  assignedAt DateTime @default(now())

  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  personnelId String
  personnel   Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  @@id([taskId, personnelId])
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

model TaskAssignee {
  assignedAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

// ─── Label ───────────────────────────────────────────────────────────────────

model Label {
  id    String @id @default(uuid())
  name  String
  color String @default("#6366f1")

  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]
}

model TaskLabel {
  taskId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

// ─── Comment ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId   String
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User     @relation(fields: [authorId], references: [id])
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies  Comment[] @relation("Replies")
}

// ─── Attachment ──────────────────────────────────────────────────────────────

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String
  createdAt    DateTime @default(now())

  taskId       String
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  COMMENT_ADDED
  MENTION
  DUE_DATE_APPROACHING
  PROJECT_INVITATION
}

// ─── ActivityLog ─────────────────────────────────────────────────────────────

model ActivityLog {
  id         String         @id @default(uuid())
  action     ActivityAction
  entityType String
  entityId   String
  entityName String
  metadata   Json?
  createdAt  DateTime       @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  UNASSIGNED
  COMMENTED
  UPLOADED
  STATUS_CHANGED
  PRIORITY_CHANGED
  MOVED
}

// ─── RefreshToken ────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── WorkLog (워크로드 / 일감) ───────────────────────────────────────────────

enum WorkLogStage {
  RECEIVED
  DEVELOPMENT
  COMPLETED
  USER_CONFIRMED
  DEPLOYED
}

model WorkLog {
  id          String        @id @default(uuid())
  description String?
  requester   String?
  hours       Float         @default(0)
  workDate    DateTime      @default(now())
  startDate   DateTime?
  endDate     DateTime?
  stage       WorkLogStage  @default(RECEIVED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  isAcknowledged  Boolean   @default(false)
  acknowledgedAt  DateTime?
  userConfirmedAt DateTime?

  taskTitle   String?
  projectName String?

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ─── Notice (공지사항) ────────────────────────────────────────────────────────

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("NoticeCreator", fields: [createdById], references: [id])
}

// ─── Issue (이슈관리) ─────────────────────────────────────────────────────────

model Issue {
  id          String        @id @default(uuid())
  title       String
  description String?
  riskLevel   IssueRisk     @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User          @relation("IssueCreator", fields: [createdById], references: [id])
  assigneeId  String?
  assignee    User?         @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
}

enum IssueRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  ON_HOLD
}

// ─── Meeting (회의록) ─────────────────────────────────────────────────────────

model Meeting {
  id           String               @id @default(uuid())
  title        String
  content      String?
  meetingDate  DateTime             @default(now())
  startTime    String?
  endTime      String?
  attendees    String?
  location     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  projectId    String?
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                 @relation("MeetingCreator", fields: [createdById], references: [id])
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String  @id @default(uuid())
  meetingId String
  userId    String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

// ─── Canvas ──────────────────────────────────────────────────────────────────

model Canvas {
  id        String   @id @default(uuid())
  name      String   @default("새 캔버스")
  data      Json     @default("{\"nodes\":[],\"edges\":[]}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("CanvasCreator", fields: [createdById], references: [id])
  comments    CanvasComment[]
}

model CanvasComment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  canvasId  String
  canvas    Canvas   @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("CanvasCommentAuthor", fields: [userId], references: [id])
}

// ─── Sheet (스프레드시트) ─────────────────────────────────────────────────────

model Sheet {
  id        String   @id @default(uuid())
  name      String   @default("시트1")
  order     Int      @default(0)
  data      Json     @default("{\"cells\":{},\"rows\":100,\"cols\":26}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("SheetCreator", fields: [createdById], references: [id])
}

// ─── Message (사용자 간 쪽지) ──────────────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId])
  @@index([recipientId, isRead])
}

// ─── Room (그룹채팅방) ────────────────────────────────────────────────────────

model Room {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User          @relation("RoomCreator", fields: [createdById], references: [id])
  members     RoomMember[]
  messages    RoomMessage[]
}

model RoomMember {
  joinedAt DateTime @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
}

model RoomMessage {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  roomId   String
  room     Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId String
  sender   User @relation("RoomMessageSender", fields: [senderId], references: [id])
}

// ─── Template (프로젝트 단계별 템플릿 양식) ────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  title       String
  phase       String   // 프로젝트 단계 (예: 기획, 설계, 개발, 테스트, 배포 — 자유 입력)
  description String?
  content     String?  // 템플릿 본문 (텍스트/마크다운)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id])

  files       TemplateFile[]

  @@index([phase])
}

model TemplateFile {
  id           String   @id @default(uuid())
  filename     String   // 서버 저장 파일명
  originalName String   // 원본 파일명
  mimetype     String
  size         Int
  url          String
  createdAt    DateTime @default(now())

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}
